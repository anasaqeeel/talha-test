# NextAuth (required for auth to work)
# Generate one: openssl rand -base64 32
AUTH_SECRET=your-secret-here

# Optional: Surveillance backend (defaults below)
# NEXT_PUBLIC_SURVEILLANCE_URL=http://localhost:4000
# SURVEILLANCE_PORT=4000

# Database (if using Prisma)
# DATABASE_URL="postgresql://..."

# Google OAuth (optional – for "Sign in with Google" on login page)
# Get from https://console.cloud.google.com/apis/credentials (create OAuth 2.0 Client ID, type: Web app)
# For localhost: set Authorized redirect URI to http://localhost:3000/api/auth/callback/google (or 3003 if you use that port)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
